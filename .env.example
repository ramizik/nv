# ============================================================================
# Local Voice Lead Closer — environment config
# Copy to `.env` (repo root). Backend reads this. Safe defaults = full mock demo.
# ============================================================================

# --- Inference: 'mock' (default, zero deps) | 'nemotron' (real GB10 box) ---
INFERENCE_BACKEND=mock

# Only used when INFERENCE_BACKEND=nemotron. Point DIRECTLY at the GB10 model server
# (vLLM/NIM serving Nemotron-Super) — NOT at Hermes (Hermes defaults to cloud Gemini).
# e.g. vLLM/NIM:  http://<gb10-host-or-ip>:8000/v1   ·  NEMOTRON_MODEL = id from /v1/models
NEMOTRON_BASE_URL=http://localhost:8000/v1
NEMOTRON_MODEL=nvidia/nemotron
NEMOTRON_API_KEY=not-needed

# --- Chat alerts: 'mock' (default, preview) | 'hermes' (teammate's bot) | 'discord' (raw webhook) ---
CHAT_BACKEND=mock

# 'hermes' path — hand the alert to the teammate's Hermes service (it owns the Discord bot).
# HERMES_API_KEY = Hermes' API_SERVER_KEY (ask the teammate). Hermes binds 127.0.0.1, so this
# only works if THIS backend runs on the GB10 box or you SSH-tunnel :8642. See docs/hermes-integration.md.
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=
HERMES_DISCORD_CHANNEL=1509734278206984194

# 'discord' path (secondary fallback only — raw webhook, not the bot):
# Discord server -> Channel -> Edit -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# --- Frontend dev origin for CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173

# --- Frontend: where the API lives (used by Vite) ---
VITE_API_BASE=http://localhost:8080
