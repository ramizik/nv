# ============================================================================
# Local Voice Lead Closer — environment config
# Copy to `.env` (repo root). Backend reads this. Safe defaults = full mock demo.
#
# Architecture: the backend (Lead Analyzer) uses local Qwen3-30B via Ollama for
# the main conversational/scoring brain, and Hermes for agent/tool execution and
# alert delivery. NVIDIA NIM sidecars expose embeddings and voice output.
# ============================================================================

# --- Inference: 'mock' (zero deps) | 'qwen' (GB10 local Qwen) | 'hermes' (Hermes provider) ---
INFERENCE_BACKEND=qwen

# --- Chat alerts: 'mock' (default, preview) | 'hermes' (via the bot) | 'discord' (raw webhook) ---
CHAT_BACKEND=mock

# --- Hermes: agent/actions/alerts gateway ----------------------------------------------------
# Hermes binds 127.0.0.1, so this only works if THIS backend runs on the GB10 box or via tunnel.
# Protected routes need the gateway bearer = API_SERVER_KEY from ~/.hermes/.env.
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=
HERMES_DISCORD_CHANNEL=1509734278206984194
# Reasoning model override for INFERENCE_BACKEND=hermes only. Locked to the local GB10 Qwen model.
HERMES_INFERENCE_MODEL=Qwen3-30B:latest
HERMES_TIMEOUT_READ=60
#
# Alert delivery sub-path (CHAT_BACKEND=hermes):
# PRIMARY (deterministic, no LLM, on-box): a Hermes webhook `deliver_only` route (deliver: discord)
# the owner adds in ~/.hermes/config.yaml. Set HERMES_WEBHOOK_URL to that route's URL; leave the
# secret blank for the demo (INSECURE_NO_AUTH) or set it if the route uses HMAC.
HERMES_WEBHOOK_URL=
HERMES_WEBHOOK_SECRET=
# (If HERMES_WEBHOOK_URL is blank, the alert falls back to /v1/chat/completions, which also needs
#  HERMES_API_KEY above. Still on-box via local Qwen, but LLM-mediated so non-deterministic.)

# --- Local Qwen main/default conversational brain -------------------------------------------
QWEN_BASE_URL=http://127.0.0.1:11434/v1
QWEN_MODEL=Qwen3-30B:latest
QWEN_API_KEY=not-needed
QWEN_TIMEOUT_READ=240
QWEN_THINKING_DIRECTIVE=/no_think

# --- NVIDIA NIM sidecars on GB10 ------------------------------------------------------------
EMBED_BASE_URL=http://127.0.0.1:8001/v1
EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
EMBED_INPUT_TYPE_QUERY=query

TTS_BASE_URL=http://127.0.0.1:8003/v1
TTS_VOICE=Magpie-Multilingual.EN-US.Mia.Neutral
TTS_LANGUAGE=en-US
TTS_SAMPLE_RATE_HZ=22050

ASR_BACKEND=nemotron-asr-streaming
ASR_BASE_URL=http://127.0.0.1:8002/v1
ASR_RUNTIME_STATUS=ready: nemotron-asr-streaming NIM on :8002, realtime sessions enabled
PARAKEET_BASE_URL=
PARAKEET_RUNTIME_STATUS=blocked: parakeet-0.6b-tdt image on this host is linux/amd64 and cannot run on GB10 linux/arm64

# 'discord' path (secondary fallback only — raw webhook, not the bot):
# Discord server -> Channel -> Edit -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# --- Frontend dev origin for CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173

# --- Frontend: where the API lives (used by Vite) ---
# NOTE: on the GB10 box, :8080 is already taken by LifeOS. Run this backend on :8090.
VITE_API_BASE=http://localhost:8090
