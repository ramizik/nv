# ============================================================================
# Local Voice Lead Closer — environment config
# Copy to `.env` (repo root). Backend reads this. Safe defaults = full mock demo.
# ============================================================================

# --- Inference: 'mock' (default, zero deps) | 'nemotron' (real GB10 box) ---
INFERENCE_BACKEND=mock

# Only used when INFERENCE_BACKEND=nemotron. Point DIRECTLY at the GB10 model server —
# NOT at Hermes (Hermes defaults to cloud Gemini). CONFIRMED on the box: Nemotron-120B is
# served via Ollama (OpenAI-compatible) at :11434/v1, no API key. The optional cheap path is
# lifeos-qwen3-30b:latest. ⚠️ ~120 GB total ⇒ ONLY ONE local model resident at a time:
# pre-warm exactly one for the demo (no voice/embed loaded alongside it).
NEMOTRON_BASE_URL=http://127.0.0.1:11434/v1
NEMOTRON_MODEL=lifeos-nemotron-120b:latest
NEMOTRON_API_KEY=not-needed
# Read timeout (s); 120B can be slow cold. Pre-warm to avoid hitting this.
NEMOTRON_TIMEOUT_READ=90

# --- Chat alerts: 'mock' (default, preview) | 'hermes' (teammate's bot) | 'discord' (raw webhook) ---
CHAT_BACKEND=mock

# 'hermes' path — hand the alert to the teammate's Hermes service (it owns the Discord bot).
# Hermes binds 127.0.0.1, so this only works if THIS backend runs on the GB10 box (or tunnel :8642).
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_DISCORD_CHANNEL=1509734278206984194
#
# PRIMARY (deterministic, no LLM, on-box): the Hermes webhook `deliver_only` route the owner
# adds in ~/.hermes/config.yaml. Set this to that route's URL; leave the secret blank for the
# demo (INSECURE_NO_AUTH) or set it if the route uses HMAC.
HERMES_WEBHOOK_URL=
HERMES_WEBHOOK_SECRET=
#
# FALLBACK (only if the webhook isn't wired): /v1/chat/completions routes through the cloud
# agent model and REQUIRES the gateway bearer = API_SERVER_KEY from ~/.hermes/.env. Without it
# every call 401s ("invalid_api_key"). Non-deterministic + off-box — avoid for the real demo.
HERMES_API_KEY=

# 'discord' path (secondary fallback only — raw webhook, not the bot):
# Discord server -> Channel -> Edit -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# --- Frontend dev origin for CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173

# --- Frontend: where the API lives (used by Vite) ---
# NOTE: on the GB10 box, :8080 is already taken (another uvicorn) — run our backend on :8090
# (uvicorn app.main:app --port 8090) and set VITE_API_BASE / CORS_ORIGINS to match.
VITE_API_BASE=http://localhost:8080
