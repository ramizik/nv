# ============================================================================
# Local Voice Lead Closer — environment config
# Copy to `.env` (repo root). Backend reads this. Safe defaults = full mock demo.
#
# Architecture: the backend (Lead Analyzer) does NOT run its own model. The REAL path
# routes BOTH reasoning and alerts through **Hermes** (the teammate's local gateway on the
# GB10). Hermes delegates reasoning to its local default model — **Qwen3-30B via Ollama** —
# so everything stays on-box: patient conversations never leave the building.
# ============================================================================

# --- Inference: 'mock' (default, zero deps) | 'hermes' (real: Hermes -> local Qwen3-30B) ---
# 'qwen' (or legacy 'nemotron') = optional DIRECT-to-Ollama fallback if Hermes is unavailable.
INFERENCE_BACKEND=mock

# --- Chat alerts: 'mock' (default, preview) | 'hermes' (via the bot) | 'discord' (raw webhook) ---
CHAT_BACKEND=mock

# --- Hermes: our SINGLE integration point (reasoning + alerts) -------------------------------
# Hermes binds 127.0.0.1, so this only works if THIS backend runs on the GB10 box (or tunnel :8642).
# Every Hermes route needs the gateway bearer = API_SERVER_KEY from ~/.hermes/.env (the gateway
# 401s "invalid_api_key" without it). The model behind Hermes is itself keyless.
HERMES_BASE_URL=http://127.0.0.1:8642
HERMES_API_KEY=
HERMES_DISCORD_CHANNEL=1509734278206984194
# Reasoning model override. Blank = Hermes' configured default (Qwen3-30B) — what we want.
# Set to lifeos-nemotron-120b:latest only to force the heavier (slower) deep-reasoning model.
HERMES_INFERENCE_MODEL=
# Read timeout (s) for the reasoning call. Qwen3-30B is fast when resident; raise for the 120B.
HERMES_TIMEOUT_READ=60
#
# Alert delivery sub-path (CHAT_BACKEND=hermes):
# PRIMARY (deterministic, no LLM, on-box): a Hermes webhook `deliver_only` route (deliver: discord)
# the owner adds in ~/.hermes/config.yaml. Set HERMES_WEBHOOK_URL to that route's URL; leave the
# secret blank for the demo (INSECURE_NO_AUTH) or set it if the route uses HMAC.
HERMES_WEBHOOK_URL=
HERMES_WEBHOOK_SECRET=
# (If HERMES_WEBHOOK_URL is blank, the alert falls back to /v1/chat/completions, which also needs
#  HERMES_API_KEY above. Still on-box via local Qwen, but LLM-mediated so non-deterministic.)

# --- DIRECT-to-Ollama fallback (only when INFERENCE_BACKEND=qwen) ----------------------------
# Bypasses Hermes and calls the local Ollama OpenAI endpoint ourselves. Qwen3-30B is fast and
# coexists with the NIM voice stack; lifeos-nemotron-120b:latest is the heavier alternative.
# ⚠️ ~120 GB unified memory ⇒ ONLY ONE large model resident at a time. Legacy NEMOTRON_* vars
# are still honored as a fallback for these.
QWEN_BASE_URL=http://127.0.0.1:11434/v1
QWEN_MODEL=Qwen3-30B:latest
QWEN_API_KEY=not-needed
QWEN_TIMEOUT_READ=60
QWEN_THINKING_DIRECTIVE=/no_think

# 'discord' path (secondary fallback only — raw webhook, not the bot):
# Discord server -> Channel -> Edit -> Integrations -> Webhooks -> New Webhook -> Copy URL
DISCORD_WEBHOOK_URL=

# --- Frontend dev origin for CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173

# --- Frontend: where the API lives (used by Vite) ---
# NOTE: on the GB10 box, :8080 is already taken (another uvicorn) — run our backend on :8090
# (uvicorn app.main:app --port 8090) and set VITE_API_BASE / CORS_ORIGINS to match.
VITE_API_BASE=http://localhost:8080
